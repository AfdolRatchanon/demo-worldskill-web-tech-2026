# =========================================================================
# Dependencies — ติดตั้งใหม่ได้ด้วย npm install ไม่ต้องเก็บขึ้น git
# =========================================================================
node_modules/
**/node_modules/

# =========================================================================
# Environment / ความลับ — ห้ามขึ้น git (มีรหัสผ่าน DB + JWT secret)
# ผู้ใช้ต้องสร้างเองจาก .env.example ตามขั้นตอนใน README
# =========================================================================
.env
**/.env
.env.local
**/.env.local
.env.*.local
**/.env.*.local
# แต่ยังเก็บไฟล์ตัวอย่างไว้ให้คนอื่นก๊อปไปใช้
!.env.example
!**/.env.example

# =========================================================================
# Build output — สร้างใหม่ได้ด้วย npm run build
# =========================================================================
dist/
**/dist/
build/
**/build/
.vite/
**/.vite/

# =========================================================================
# Logs
# =========================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================================================
# OS / Editor
# =========================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
